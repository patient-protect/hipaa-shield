{
  "manifest_version": 3,
  "name": "HIPAA Shield — PHI Detection for Browsers",
  "short_name": "HIPAA Shield",
  "version": "0.1.0",
  "description": "Detects Protected Health Information typed into browser forms — especially AI chat tools. 100% client-side. Zero telemetry.",
  "homepage_url": "https://patient-protect.com/hipaa-shield",
  "author": "Patient Protect LLC",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "HIPAA Shield — PHI detection settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "css": ["src/content-script.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "permissions": ["storage"],
  "host_permissions": []
}
